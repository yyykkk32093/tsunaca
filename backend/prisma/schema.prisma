generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- OutboxEvent テーブル定義 ----

model OutboxEvent {
  id             String    @id
  idempotencyKey String    @unique
  aggregateId    String
  eventName      String
  eventType      String
  routingKey     String
  payload        Json
  occurredAt     DateTime
  publishedAt    DateTime?
  status         String    @default("PENDING")

  retryCount  Int      @default(0)
  nextRetryAt DateTime @default(now())

  @@index([status, nextRetryAt])
}

model OutboxRetryPolicy {
  routingKey   String @id // Handler に対応する routingKey
  maxRetries   Int    @default(5) // 最大リトライ回数
  baseInterval Int    @default(3000) // 初期インターバル（ms）
  maxInterval  Int    @default(60000) // インターバル上限（ms）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthAuditLog {
  id         String   @id @default(uuid())
  action     String // auth.login.success | auth.login.failed | user.registered
  userId     String
  authMethod String
  detail     String?
  occurredAt DateTime
  createdAt  DateTime @default(now())

  @@index([userId, occurredAt])
}

model OutboxDeadLetter {
  id String @id @default(uuid())

  outboxEventId String
  routingKey    String
  eventType     String

  payload        Json
  errorMessage   String?
  errorStack     String?
  errorType      String // IntegrationError.errorType (e.g. HANDLER_NOT_FOUND, HTTP_CLIENT_ERROR)
  retryCount     Int     @default(0)
  lastHttpStatus Int? // HttpIntegrationError の statusCode（該当しない場合 null）

  occurredAt DateTime // 元イベントの発生時刻
  failedAt   DateTime @default(now())
}

model Activity {
  id                      String    @id @default(uuid())
  communityId             String
  title                   String
  description             String?
  defaultPlaceId          String? // 候補マスタ参照（Place）。defaultLocationCustom と XOR
  defaultLocationCustom   String? // 自由入力（候補不一致時）。defaultPlaceId と XOR
  isOnline                Boolean   @default(false) // オンライン開催フラグ。true 時は会場情報なし
  defaultStartTime        String? // "HH:mm" format
  defaultEndTime          String? // "HH:mm" format
  defaultParticipationFee Int? // デフォルト参加費（繰り返し生成時に引き継ぎ）
  defaultVisitorFee       Int? // デフォルトビジター費（繰り返し生成時に引き継ぎ）
  defaultCapacity         Int? // デフォルト定員（繰り返し生成時に引き継ぎ）
  allowVisitorWaitlist    Boolean   @default(false) // ビジターのキャンセル待ち参加を許可
  visibility              String    @default("PRIVATE") // 'PUBLIC' | 'PRIVATE' — Wave6 W6-04: アクティビティ公開範囲
  recurrenceRule          String? // null in Phase 1
  organizerUserId         String? // 幹事ユーザーID（null = 未定）
  createdBy               String
  deletedAt               DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  community     Community      @relation(fields: [communityId], references: [id])
  defaultPlace  Place?         @relation(fields: [defaultPlaceId], references: [id])
  schedules     Schedule[]
  chatChannel   ChatChannel?
  announcements Announcement[] // Phase3 #4: アクティビティ由来のお知らせ

  @@index([communityId])
  @@index([createdBy])
  @@index([organizerUserId])
  @@index([defaultPlaceId])
}

// Wave6 Phase6 W6-07: 開催場所マスタ（OSM由来）
// - source/sourceId で OSM の安定IDを保持し再取得時のupsertキーとする
// - normalizedName/normalizedAddress に pg_trgm GIN インデックスを付与（migration内 raw SQL）
// - usageCount は Activity 保存時にインクリメント
model Place {
  id                String  @id @default(uuid())
  name              String  @db.VarChar(200)
  address           String  @db.VarChar(500)
  lat               Float
  lng               Float
  normalizedName    String  @db.VarChar(200) // 検索用正規化名（小文字・記号除去）
  normalizedAddress String  @db.VarChar(500) // 検索用正規化住所
  category          String? @db.VarChar(50) // OSM由来カテゴリ（sports_centre / community_centre 等）
  source            String  @db.VarChar(20) // 'osm' 等
  sourceId          String  @db.VarChar(100) // 'osm:node:123456' / 'osm:way:...' 形式の安定ID
  usageCount        Int     @default(0)
  isActive          Boolean @default(true) // false = 最新スナップショットから消えた等で論理削除

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities Activity[]

  @@unique([source, sourceId])
  @@index([isActive, usageCount(sort: Desc)])
}

model Schedule {
  id               String    @id @default(uuid())
  activityId       String
  date             DateTime  @db.Date
  startTime        String // "HH:mm" format
  endTime          String // "HH:mm" format
  location         String?
  note             String?
  status           String    @default("SCHEDULED") // SCHEDULED | CANCELLED
  capacity         Int?
  participationFee Int       @default(0) // 参加費（円）。0 = 無料
  visitorFee       Int? // ビジター参加費（null = 通常参加費と同額）
  isOnline         Boolean   @default(false)
  meetingUrl       String? // オンライン時の会議URL
  visibility       String? // null = Activity を継承 / 'PUBLIC' | 'PRIVATE' — Wave6 W6-04: スケジュール個別の公開範囲オーバーライド
  deletedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activity               Activity                @relation(fields: [activityId], references: [id])
  participations         Participation[]
  waitlistEntries        WaitlistEntry[]
  participationAuditLogs ParticipationAuditLog[]
  payments               Payment[]
  matchingResult         MatchingResult?

  @@index([activityId])
  @@index([date])
}

model Participation {
  id           String   @id @default(uuid())
  scheduleId   String
  userId       String? // 登録済みユーザーの場合はユーザーID。未登録ビジターの場合はnull
  isVisitor    Boolean  @default(false)
  visitorName  String?  @db.VarChar(50) // 未登録ビジターの表示名（isVisitor=true & userId=null 時に必須）
  visitorLevel Int? // ビジターの競技レベル（0-8）。null の場合はコミュニティ平均を適用
  addedBy      String? // ビジター追加者のユーザーID
  respondedAt  DateTime @default(now())

  schedule Schedule  @relation(fields: [scheduleId], references: [id])
  payments Payment[] // Payment との1:N関連（通常1:1だが返金等で複数の可能性）

  // userId が NOT NULL の場合のみユニーク制約（部分インデックスはマイグレーションSQLで手動定義）
  @@index([scheduleId])
  @@index([userId])
}

// 決済テーブル — Participation とは独立したライフサイクルを持つ
// キャンセル後も Payment レコードは残り、返金ステータスを追跡できる
model Payment {
  id                    String    @id @default(uuid())
  scheduleId            String
  participationId       String? // Participation との紐付け（未登録ビジター含む全参加者を確実に辿れる）
  userId                String? // 登録済みユーザーの場合のみ設定（高速参照用の補助カラム）
  paymentMethod         String? // CASH | PAYPAY | CREDIT_CARD | null（未決定=ビジター初期状態「ー」）
  displayName           String?   @db.VarChar(100) // 支払い時点の表示名スナップショット（登録ユーザー=displayName, ビジター=visitorName）
  amount                Int // 参加費
  feeAmount             Int       @default(0) // プラットフォーム手数料
  status                String    @default("UNPAID") // UNPAID | REPORTED | CONFIRMED | REJECTED | REFUND_PENDING | REFUNDED | NO_REFUND
  stripePaymentIntentId String?
  paymentReportedAt     DateTime?
  paymentConfirmedAt    DateTime?
  paymentConfirmedBy    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schedule      Schedule       @relation(fields: [scheduleId], references: [id])
  participation Participation? @relation(fields: [participationId], references: [id])

  @@index([scheduleId, userId])
  @@index([participationId])
  @@index([stripePaymentIntentId])
}

model WaitlistEntry {
  id           String   @id @default(uuid())
  scheduleId   String
  userId       String?
  isVisitor    Boolean  @default(false)
  visitorName  String?
  addedBy      String?
  registeredAt DateTime @default(now())

  schedule Schedule @relation(fields: [scheduleId], references: [id])

  // userId が NOT NULL の場合のみユニーク制約（部分インデックスはマイグレーションSQLで手動定義）
  @@index([scheduleId, userId])
  @@index([scheduleId, registeredAt])
}

model User {
  id                  String    @id @default(uuid())
  displayName         String?
  plan                String    @default("FREE")
  /// プラットフォーム（運営側）権限。テナント内の CommunityMembership.role とは別概念。
  /// 'USER' | 'OPERATOR' | 'SUPER_ADMIN'
  /// USER: 一般利用者 / OPERATOR: 運営オペレーター（問い合わせ対応・ヘルプ管理）/ SUPER_ADMIN: 全権
  systemRole          String    @default("USER") @map("system_role")
  email               String?   @unique
  phone               String?
  avatarUrl           String?
  biography           String?
  notificationSetting Json
  /// Wave6 Phase 9b-05: 表示言語（'ja' | 'en'）。null = 未設定（クライアントが localStorage / navigator.language で判定）
  locale              String?
  deletedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passwordCredential PasswordCredential?
  googleCredential   GoogleCredential?
  lineCredential     LineCredential?
  appleCredential    AppleCredential?

  authSecurityState AuthSecurityState?

  // Phase 2.5: 参加リクエスト
  communityJoinRequests CommunityJoinRequest[]

  // Chat: 送信メッセージ
  messages Message[] @relation("UserMessages")

  // Phase4: 収支機能
  expenses Expense[]

  // Wave4: 退会記録
  withdrawal UserWithdrawal?

  // W5-25: チャンネル既読状態
  channelReadStates ChannelReadState[]

  // Wave6 Phase 8-B: 問い合わせ（認証ユーザー側）
  inquiries Inquiry[] @relation("UserInquiries")

  // Wave6 Phase 9b-16: 問い合わせ担当（運営側）
  assignedInquiries Inquiry[] @relation("InquiryAssignee")

  // Wave6 Phase10: 組み合わせ結果
  matchingResults MatchingResult[]
}

// ============================================================
// UserWithdrawal（Wave4: 退会理由記録）
// ============================================================

model UserWithdrawal {
  id       String  @id @default(uuid())
  userId   String  @unique
  reason   String // 'NOT_USING' | 'FOUND_ALTERNATIVE' | 'HARD_TO_USE' | 'FEE_TOO_HIGH' | 'OTHER'
  freeText String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthSecurityState {
  userId String @id @map("user_id")

  /**
   * 最後に成功した認証方式（例: password/google/line/apple）
   */
  authMethod String? @map("auth_method")

  /**
   * 最終ログイン成功時刻（結果整合の投影）
   */
  lastLoginAt DateTime? @map("last_login_at")

  /**
   * セキュリティ判定向け（最小）
   */
  failedSignInCount Int       @default(0) @map("failed_sign_in_count")
  lockedUntil       DateTime? @map("locked_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lockedUntil])
  @@map("auth_security_states")
}

model PasswordCredential {
  userId         String   @id
  hashedPassword String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoogleCredential {
  userId    String   @unique
  googleUid String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LineCredential {
  userId    String   @unique
  lineUid   String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppleCredential {
  userId    String   @unique
  appleUid  String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---- Community ----

model Community {
  id          String    @id @default(uuid())
  name        String
  description String?
  logoUrl     String?
  coverUrl    String?
  parentId    String?
  depth       Int       @default(0)
  grade       String    @default("FREE") // 'FREE' | 'PREMIUM'
  createdBy   String
  deletedAt   DateTime?

  // ---- Phase 2: Community Profile Fields ----
  joinMethod          String   @default("FREE_JOIN") // 'FREE_JOIN' | 'APPROVAL' | 'INVITATION'
  isPublic            Boolean  @default(true)
  maxMembers          Int?
  activityFrequency   String?
  targetGender        String[] @default([]) // GenderTarget VO で型安全を担保
  ageMin              Int? // Wave5: 対象年齢下限（0-130）
  ageMax              Int? // Wave5: 対象年齢上限（0-130）
  recommendedLevelMin Int? // Wave5: 推奨レベル下限（0-8スケール）
  recommendedLevelMax Int? // Wave5: 推奨レベル上限（0-8スケール）

  // UBL-8: Payment settings
  payPayId              String?
  enabledPaymentMethods String[] @default(["CASH"])
  stripeAccountId       String? // Stripe Connect アカウントID（Destination Charges 用）

  // Phase 3: Community Notification Settings
  reminderEnabled          Boolean @default(true) // スケジュール/支払いリマインダーを送信するか
  cancellationAlertEnabled Boolean @default(true) // 当日キャンセル時に管理者にアラートを送信するか

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Community?  @relation("CommunityHierarchy", fields: [parentId], references: [id])
  children Community[] @relation("CommunityHierarchy")

  memberships   CommunityMembership[]
  activities    Activity[]
  announcements Announcement[]
  chatChannel   ChatChannel?
  albums        Album[]

  // Phase 2: 正規化リレーション
  categories          CommunityCategory[]
  participationLevels CommunityParticipationLevel[]
  activityDays        CommunityActivityDay[]
  tags                CommunityTag[]

  // Phase 2.5: 参加リクエスト
  joinRequests CommunityJoinRequest[]

  // UBL-34: 投票
  polls Poll[]

  // UBL-29: Webhook 連携
  webhookConfigs CommunityWebhookConfig[]

  // Phase3 #53: コミュニティブックマーク
  bookmarks CommunityBookmark[]

  // Phase4: 収支機能
  expenses          Expense[]
  expenseCategories ExpenseCategory[]

  // Wave4: 拠点管理
  locations CommunityLocation[]

  @@index([createdBy])
  @@index([parentId])
}

model CommunityMembership {
  id          String    @id @default(uuid())
  communityId String
  userId      String
  role        String    @default("MEMBER") // 'OWNER' | 'ADMIN' | 'MEMBER'
  level       Int? // メンバーのコミュニティ内レベル（0-8）
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
}

// ============================================================
// CommunityLocation（Wave4: 複数拠点管理）
// ============================================================

model CommunityLocation {
  id          String  @id @default(uuid())
  communityId String
  type        String // 'MAIN' | 'SUB'
  area        String // 活動エリア名（例: 「渋谷」「新宿」）
  station     String? // 最寄り駅（任意）
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
}

// ============================================================
// CommunityJoinRequest（Phase 2.5: 承認制参加リクエスト）
// ============================================================

model CommunityJoinRequest {
  id          String    @id @default(uuid())
  communityId String
  userId      String
  status      String    @default("PENDING") // 'PENDING' | 'APPROVED' | 'REJECTED'
  message     String?
  reviewedBy  String?
  reviewedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id])

  @@unique([communityId, userId, status])
  @@index([communityId])
  @@index([userId])
}

// ============================================================
// Announcement
// ============================================================

model Announcement {
  id          String    @id @default(uuid())
  communityId String
  authorId    String
  activityId  String? // Phase3 #4: アクティビティ由来のお知らせ紐付け
  title       String
  content     String
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  community   Community                @relation(fields: [communityId], references: [id], onDelete: Cascade)
  activity    Activity?                @relation(fields: [activityId], references: [id], onDelete: SetNull)
  reads       AnnouncementRead[]
  likes       AnnouncementLike[]
  comments    AnnouncementComment[]
  attachments AnnouncementAttachment[]
  bookmarks   AnnouncementBookmark[]
  polls       Poll[]

  @@index([communityId])
  @@index([authorId])
  @@index([activityId])
}

model AnnouncementRead {
  id             String   @id @default(uuid())
  announcementId String
  userId         String
  readAt         DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

// ============================================================
// UBL-1: AnnouncementLike（いいね）
// ============================================================

model AnnouncementLike {
  id             String   @id @default(uuid())
  announcementId String
  userId         String
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

// ============================================================
// UBL-2: AnnouncementComment（コメント）
// ============================================================

model AnnouncementComment {
  id             String   @id @default(uuid())
  announcementId String
  userId         String
  content        String
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([announcementId, createdAt])
  @@index([userId])
}

// ============================================================
// UBL-3: AnnouncementAttachment（お知らせ画像添付）
// ============================================================

model AnnouncementAttachment {
  id             String @id @default(uuid())
  announcementId String
  fileUrl        String
  fileName       String
  mimeType       String
  fileSize       Int
  sortOrder      Int    @default(0)

  createdAt DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@index([announcementId])
}

// ============================================================
// Phase 3 (3-1): AnnouncementBookmark（お知らせブックマーク）
// ============================================================

model AnnouncementBookmark {
  id             String   @id @default(uuid())
  announcementId String
  userId         String
  createdAt      DateTime @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId])
}

// ============================================================
// UBL-6: Album / AlbumPhoto
// ============================================================

model Album {
  id          String  @id @default(uuid())
  communityId String
  title       String
  description String?
  createdBy   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  community Community    @relation(fields: [communityId], references: [id], onDelete: Cascade)
  photos    AlbumPhoto[]

  @@index([communityId])
}

model AlbumPhoto {
  id         String @id @default(uuid())
  albumId    String
  fileUrl    String
  fileName   String
  mimeType   String
  fileSize   Int
  uploadedBy String

  createdAt DateTime @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
}

// ============================================================
// FeatureGate — 機能制限テーブル (memo.md §6)
// ============================================================

model UserFeatureRestriction {
  id      String  @id @default(uuid())
  plan    String // 'FREE' | 'LITE' | 'PRO' | 'LIFETIME'
  feature String // Feature enum の値
  enabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([plan, feature])
  @@index([plan])
}

model UserLimitRestriction {
  id       String @id @default(uuid())
  plan     String // 'FREE' | 'LITE' | 'PRO' | 'LIFETIME'
  limitKey String // 'maxJoinCommunities' | 'maxCustomStamps' etc.
  value    Int // -1 = 無制限

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([plan, limitKey])
  @@index([plan])
}

model CommunityFeatureRestriction {
  id      String  @id @default(uuid())
  grade   String // 'FREE' | 'PREMIUM'
  feature String // CommunityFeature enum の値
  enabled Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([grade, feature])
  @@index([grade])
}

model CommunityLimitRestriction {
  id       String @id @default(uuid())
  grade    String // 'FREE' | 'PREMIUM'
  limitKey String // 'maxMembers' etc.
  value    Int // -1 = 無制限

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([grade, limitKey])
  @@index([grade])
}

// ============================================================
// ChatChannel + Message
// ============================================================

// ============================================================
// UBL-10: CommunityAuditLog（コミュニティ設定変更履歴）
// ============================================================

model CommunityAuditLog {
  id          String  @id @default(uuid())
  communityId String
  actorUserId String
  action      String // COMMUNITY_UPDATED | ROLE_CHANGED | MEMBER_REMOVED | OWNER_TRANSFERRED | MEMBER_ADDED
  field       String? // 変更フィールド名 (e.g. "name", "visibility")
  before      String? // 変更前値 JSON
  after       String? // 変更後値 JSON
  summary     String // 人間可読サマリ (e.g. "コミュニティ名を変更")

  createdAt DateTime @default(now())

  @@index([communityId, createdAt])
}

// ============================================================
// ParticipationAuditLog（参加履歴 — 物理削除に伴う監査ログ）
// ============================================================

model ParticipationAuditLog {
  id            String    @id @default(uuid())
  scheduleId    String
  userId        String
  action        String // JOINED | CANCELLED | REMOVED_BY_ADMIN
  cancelledAt   DateTime? // キャンセル日時（当日キャンセル判定用）
  paymentMethod String? // キャンセル時点のスナップショット
  paymentStatus String? // キャンセル時点のスナップショット
  createdAt     DateTime  @default(now())

  schedule Schedule @relation(fields: [scheduleId], references: [id])

  @@index([scheduleId, createdAt])
  @@index([userId, createdAt])
}

// ============================================================
// WaitlistAuditLog（キャンセル待ち履歴 — 物理削除に伴う監査ログ）
// ============================================================

model WaitlistAuditLog {
  id         String   @id @default(uuid())
  scheduleId String
  userId     String
  action     String // JOINED | CANCELLED | PROMOTED
  createdAt  DateTime @default(now())

  @@index([scheduleId, createdAt])
  @@index([userId, createdAt])
}

// ============================================================
// UBL-11: InviteToken（メンバー招待トークン）
// ============================================================

model InviteToken {
  id          String   @id @default(uuid())
  communityId String
  token       String   @unique @default(uuid())
  createdBy   String
  expiresAt   DateTime
  maxUses     Int? // null = 無制限
  currentUses Int      @default(0)

  createdAt DateTime @default(now())

  usages InviteTokenUsage[]

  @@index([communityId])
  @@index([token])
}

model InviteTokenUsage {
  id      String   @id @default(uuid())
  tokenId String
  userId  String
  usedAt  DateTime @default(now())

  token InviteToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)

  @@unique([tokenId, userId])
  @@index([tokenId])
}

model ChatChannel {
  id          String  @id @default(uuid())
  type        String // COMMUNITY | ACTIVITY | DM
  communityId String? @unique
  activityId  String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  community        Community?         @relation(fields: [communityId], references: [id], onDelete: Cascade)
  activity         Activity?          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  messages         Message[]
  dmParticipants   DMParticipant[]
  channelReadState ChannelReadState[]

  @@index([type])
}

model Message {
  id              String  @id @default(uuid())
  channelId       String
  senderId        String
  parentMessageId String?
  content         String
  mentions        Json    @default("[]") // UserId[]
  isPinned        Boolean @default(false)
  deletedBy       String? // Phase3 #19: ソフトデリート（削除したユーザーのID）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  channel     ChatChannel         @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender      User                @relation("UserMessages", fields: [senderId], references: [id])
  parent      Message?            @relation("MessageThread", fields: [parentMessageId], references: [id])
  replies     Message[]           @relation("MessageThread")
  attachments MessageAttachment[]
  reactions   MessageReaction[]

  @@index([channelId, createdAt])
  @@index([parentMessageId])
  @@index([senderId])
}

model MessageAttachment {
  id        String @id @default(uuid())
  messageId String
  fileUrl   String
  fileName  String
  fileSize  Int
  mimeType  String

  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model DMParticipant {
  id        String   @id @default(uuid())
  channelId String
  userId    String
  joinedAt  DateTime @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

// ============================================================
// Stamp + MessageReaction
// ============================================================

model Stamp {
  id              String @id @default(uuid())
  createdByUserId String
  name            String
  imageUrl        String

  createdAt DateTime @default(now())

  reactions MessageReaction[]

  @@index([createdByUserId])
}

model MessageReaction {
  id        String  @id @default(uuid())
  messageId String
  userId    String
  stampId   String? // Phase3 #18: nullable化（emojiリアクション時はnull）
  emoji     String? // Phase3 #18: ネイティブ絵文字リアクション（stampId使用時はnull）

  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  stamp   Stamp?  @relation(fields: [stampId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, stampId])
  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// ============================================================
// Notification
// ============================================================

model Notification {
  id            String  @id @default(uuid())
  userId        String
  type          String // MENTION | DM | ANNOUNCEMENT | WAITLIST_PROMOTED | etc.
  title         String
  body          String?
  referenceId   String? // 関連エンティティのID
  referenceType String? // MESSAGE | ANNOUNCEMENT | SCHEDULE | etc.
  metadata      Json? // 通知種別ごとの構造化メタデータ（Discriminated Union by type）
  isRead        Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
}

// ============================================================
// Device Token (FCM Push Notification)
// ============================================================

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique // FCM registration token
  platform  String // 'ios' | 'android' | 'web'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================================
// Community Master Tables (Phase 2)
// ============================================================

model CategoryMaster {
  id        String   @id @default(uuid())
  name      String   @unique
  nameEn    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  communityCategories CommunityCategory[]
  matchFormats        CategoryMatchFormat[]
}

model CategoryMatchFormat {
  id              String   @id @default(uuid())
  categoryId      String
  name            String
  playersPerGroup Int // 1組あたりの人数（シングルス=1, ダブルス=2）
  groupsPerCourt  Int      @default(2) // 1コートの同時対戦組数（通常2）
  sortOrder       Int      @default(0)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category CategoryMaster @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, name])
  @@index([categoryId, sortOrder])
}

model MatchingResult {
  id         String   @id @default(uuid())
  scheduleId String   @unique
  mode       String // RANDOM | MIXED_LEVEL | SAME_LEVEL
  params     Json
  rounds     Json
  createdBy  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  schedule Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [createdBy], references: [id])

  @@index([createdBy])
}

model ParticipationLevelMaster {
  id        String   @id @default(uuid())
  name      String   @unique
  nameEn    String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  communityLevels CommunityParticipationLevel[]
}

// ============================================================
// Community Intermediate Tables (Phase 2)
// ============================================================

model CommunityCategory {
  id          String @id @default(uuid())
  communityId String
  categoryId  String

  community Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  category  CategoryMaster @relation(fields: [categoryId], references: [id])

  @@unique([communityId, categoryId])
  @@index([categoryId])
}

model CommunityParticipationLevel {
  id          String @id @default(uuid())
  communityId String
  levelId     String

  community Community                @relation(fields: [communityId], references: [id], onDelete: Cascade)
  level     ParticipationLevelMaster @relation(fields: [levelId], references: [id])

  @@unique([communityId, levelId])
  @@index([levelId])
}

// ============================================================
// Community Value Tables (Phase 2)
// ============================================================

model CommunityActivityDay {
  id          String @id @default(uuid())
  communityId String
  day         String // 月, 火, 水, 木, 金, 土, 日

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, day])
}

model CommunityTag {
  id          String @id @default(uuid())
  communityId String
  tag         String

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, tag])
}

// ============================================================
// UBL-34: Poll / PollOption / PollVote（投票/アンケート）
// ============================================================

model Poll {
  id               String    @id @default(uuid())
  communityId      String
  announcementId   String?
  question         String
  isMultipleChoice Boolean   @default(false)
  deadline         DateTime?
  createdBy        String
  deletedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  community    Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  announcement Announcement? @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  options      PollOption[]

  @@index([communityId])
  @@index([announcementId])
  @@index([createdBy])
}

model PollOption {
  id        String @id @default(uuid())
  pollId    String
  text      String
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())

  poll  Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes PollVote[]

  @@index([pollId])
}

model PollVote {
  id           String   @id @default(uuid())
  pollOptionId String
  userId       String
  votedAt      DateTime @default(now())

  pollOption PollOption @relation(fields: [pollOptionId], references: [id], onDelete: Cascade)

  @@unique([pollOptionId, userId])
  @@index([userId])
}

// ============================================================
// UBL-29: CommunityWebhookConfig（外部通知連携）
// ============================================================

model CommunityWebhookConfig {
  id          String  @id @default(uuid())
  communityId String
  service     String // 'LINE'（将来: 'SLACK' | 'DISCORD'）
  webhookUrl  String
  enabled     Boolean @default(true)
  createdBy   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, service])
  @@index([communityId])
}

// ============================================================
// Phase3 #53: CommunityBookmark（コミュニティブックマーク）
// ============================================================

model CommunityBookmark {
  id          String @id @default(uuid())
  communityId String
  userId      String

  createdAt DateTime @default(now())

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([userId])
}

// ============================================================
// Phase4: ExpenseCategory（支出カテゴリマスタ）
// ============================================================

model ExpenseCategory {
  id          String  @id @default(uuid())
  communityId String? // null = システム共通プリセット
  name        String
  isSystem    Boolean @default(false) // true = プリセット（削除不可）
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())

  community Community? @relation(fields: [communityId], references: [id], onDelete: Cascade)
  expenses  Expense[]

  @@index([communityId])
}

// ============================================================
// Phase4: Expense（支出）
// ============================================================

model Expense {
  id          String   @id @default(uuid())
  communityId String
  categoryId  String
  amount      Int
  description String?
  date        DateTime @db.Date
  createdBy   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  community Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  category  ExpenseCategory @relation(fields: [categoryId], references: [id])
  creator   User            @relation(fields: [createdBy], references: [id])

  @@index([communityId])
  @@index([categoryId])
  @@index([createdBy])
}

// ============================================================
// W5-28: PlanMaster（プランマスタ）
// ============================================================

model PlanMaster {
  id                  String    @id // 'FREE' | 'LITE' | 'PRO' | 'LIFETIME'
  displayName         String // UI表示名
  description         String?
  monthlyPrice        Int? // 月額（円）。null = 無料 or 買い切り
  oneTimePrice        Int? // 買い切り価格（円）。LIFETIME のみ
  revenuecatProductId String? // RevenueCat の product_id
  sortOrder           Int       @default(0) // 表示順
  availableFrom       DateTime? // 販売開始日（null = 制限なし）
  availableTo         DateTime? // 販売終了日（null = 制限なし）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// W5-25: ChannelReadState（チャンネル既読状態）
// ============================================================

model ChannelReadState {
  id         String   @id @default(uuid())
  channelId  String
  userId     String
  lastReadAt DateTime @default(now())

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

// ============================================================
// Wave6 Phase 8-B: Inquiry（問い合わせ）+ Phase 7 / 9b-01: HelpFeedback
// 詳細設計: projects/00_requirements/202603_07_bugfix-and-refactoring_wave6/phase8-progress.md
// ============================================================

/// 問い合わせカテゴリマスタ（Phase 7 のヘルプカテゴリと relatedHelpCategorySlug で紐付け）
model InquiryCategory {
  id                      String  @id @default(uuid())
  /// URL/参照用の一意キー（例: 'login_trouble', 'billing', 'general'）
  slug                    String  @unique
  /// i18n ラベル: { "ja": "ログイン・登録の不具合", "en": "Login / Sign-up issue" }
  labelI18n               Json
  /// Phase 7 ヘルプカテゴリの slug 参照（紐付けがない場合は null）
  relatedHelpCategorySlug String?
  sortOrder               Int     @default(0)
  isActive                Boolean @default(true)
  /// 匿名ルート（/contact/anonymous）専用カテゴリかどうか
  /// true の場合、認証ルート (/contact) のカテゴリ選択肢に含めない
  isAnonymousOnly         Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inquiries Inquiry[]

  @@index([isActive, sortOrder])
}

/// 問い合わせスレッド本体
model Inquiry {
  id             String    @id @default(uuid())
  /// 認証ユーザー問い合わせの場合に設定。匿名問い合わせの場合 null
  userId         String?
  /// 匿名問い合わせ時の連絡先メール（運営返信先）。認証ユーザーの場合 null
  contactEmail   String?
  categoryId     String
  title          String    @db.VarChar(200)
  /// OPEN | IN_PROGRESS | RESOLVED | CLOSED
  status         String    @default("OPEN")
  /// マイページに表示される最終更新時刻（運営返信／ユーザー追記で更新）
  lastActivityAt DateTime  @default(now())
  /// RESOLVED 遷移時刻（180日経過で添付削除ジョブの判定に使用）
  resolvedAt     DateTime?
  /// Wave6 Phase 9b-16: 担当オペレーター（SystemAdmin ユーザー）。null = 未割当
  assigneeUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User?            @relation("UserInquiries", fields: [userId], references: [id])
  category InquiryCategory  @relation(fields: [categoryId], references: [id])
  assignee User?            @relation("InquiryAssignee", fields: [assigneeUserId], references: [id])
  messages InquiryMessage[]

  @@index([userId, lastActivityAt(sort: Desc)])
  @@index([status, lastActivityAt(sort: Desc)])
  @@index([categoryId])
  @@index([assigneeUserId, status])
}

/// 問い合わせスレッド内の個別メッセージ（初回送信＋運営返信＋ユーザー追記）
model InquiryMessage {
  id           String   @id @default(uuid())
  inquiryId    String
  /// 'USER' | 'OPERATOR' — 投稿者種別
  authorType   String
  /// authorType=OPERATOR の場合の運営担当者ユーザー ID。匿名や USER 投稿は null
  authorUserId String?
  body         String   @db.Text
  createdAt    DateTime @default(now())

  inquiry     Inquiry             @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  attachments InquiryAttachment[]

  @@index([inquiryId, createdAt])
}

/// 問い合わせメッセージへの添付（画像/動画/PDF/テキスト）
model InquiryAttachment {
  id         String    @id @default(uuid())
  messageId  String
  storageKey String    @unique
  fileName   String    @db.VarChar(255)
  mimeType   String    @db.VarChar(100)
  sizeBytes  Int
  /// 'PENDING' | 'CLEAN' | 'INFECTED' | 'ERROR'
  scanStatus String    @default("PENDING")
  scannedAt  DateTime?
  /// RESOLVED 後の保持期間ジョブで S3 から削除されたかどうか（メタは残す）
  isPurged   Boolean   @default(false)
  purgedAt   DateTime?

  createdAt DateTime @default(now())

  message InquiryMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([scanStatus])
  @@index([isPurged])
}

/// Phase 7 / 9b-01: ヘルプ記事フィードバック（役立った/役立たなかった）
/// 認証ユーザーは [userId, articleSlug] で一意（再投票は upsert で上書き）。
/// 匿名（userId=null）は upsert できないため、複数行が積まれる（IP rate-limit で抑制）。
model HelpFeedback {
  id           String  @id @default(uuid())
  /// ヘルプ記事のslug
  articleSlug  String  @db.VarChar(200)
  /// カテゴリslug（集計時のドメイン軸グルーピング用、9b-04 で使用）
  categorySlug String  @db.VarChar(100)
  /// 認証ユーザーの場合のみ。匿名フィードバックは null
  userId       String?
  /// true=役立った / false=役立たなかった
  helpful      Boolean
  /// 任意フリーテキスト（最大500字）
  comment      String? @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, articleSlug])
  @@index([articleSlug, createdAt])
  @@index([categorySlug, createdAt])
}
