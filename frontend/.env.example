# ========================
# 💳 Stripe（ローカル: テストキー）
# ========================
VITE_STRIPE_PUBLISHABLE_KEY=<Stripe テスト用公開キーを設定>

# ========================
# 📢 広告（Google AdSense）
# ========================
# mock = グレープレースホルダー（ローカル開発, アカウント不要）
# test = テスト広告表示（ステージング, data-adtest="on"）
# production = 本番広告
VITE_AD_MODE=mock
# AdSense パブリッシャー ID（test / production で必須）
VITE_ADSENSE_CLIENT_ID=
